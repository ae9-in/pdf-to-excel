# ─────────────────────────────────────────────────────────────
# FRONTEND ENVIRONMENT — copy this to .env.local and fill values
# ─────────────────────────────────────────────────────────────

# URL of the deployed Python FastAPI backend.
# Local dev  → http://127.0.0.1:8000
# Production → https://your-backend.railway.app  (or Render, Fly.io, etc.)
PYTHON_SERVICE_URL=http://127.0.0.1:8000

# Public settings (exposed to the browser — no secrets here)
NEXT_PUBLIC_MAX_FILE_SIZE_MB=50
NEXT_PUBLIC_APP_NAME="EarlyBird Convert"
