{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/convert/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/generate-excel/route.ts": {
      "maxDuration": 60
    }
  },
  "env": {
    "PYTHON_SERVICE_URL": "@python_service_url"
  }
}
