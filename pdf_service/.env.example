# ─────────────────────────────────────────────────────────────
# BACKEND ENVIRONMENT — copy this to .env and fill values
# ─────────────────────────────────────────────────────────────

# Anthropic API key (required for Claude-based parsing)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the Claude model
# Default: claude-3-5-sonnet-latest
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: MongoDB connection URI (for future logging/analytics)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=MyApp

# Tesseract path (Windows only — leave empty on Linux/Mac)
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
